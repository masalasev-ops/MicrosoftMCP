<Window x:Class="LearnMcpTutorial.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cv="clr-namespace:LearnMcpTutorial.Wpf.Converters"
        xmlns:models="clr-namespace:LearnMcpTutorial.Wpf.Models"
        mc:Ignorable="d"
        Title="Microsoft Learn MCP Tutorial - WPF Demo"
        Height="750" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <cv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <cv:InverseBoolConverter x:Key="InverseBool" />
        <cv:StatusToColorConverter x:Key="StatusToColor" />
        <cv:CountToVisibilityConverter x:Key="CountToVis" />
        <cv:MarkdownToFlowDocumentConverter x:Key="MarkdownConverter" />
    </Window.Resources>

    <TabControl Margin="4">
        <TabItem Header="Demo">
            <Grid Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Connection Bar -->
                <Border Grid.Row="0" Padding="8" Margin="0,0,0,6"
                        BorderBrush="{StaticResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="MCP Connection" FontWeight="Bold" Margin="0,0,0,6" />
                        <WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                <TextBlock Text="Provider:" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <ComboBox Width="100" ItemsSource="{Binding Providers}"
                                          SelectedIndex="{Binding SelectedProviderIndex}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                <TextBlock Text="Model:" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Width="150" Text="{Binding ModelId, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                <TextBlock Text="API Key:" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <PasswordBox x:Name="ApiKeyBox" Width="180" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,4"
                                        Visibility="{Binding ShowBaseUrl, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Base URL:" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Width="200" Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                                <TextBlock Text="Server:" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <ComboBox Width="150" ItemsSource="{Binding TransportModes}"
                                          SelectedIndex="{Binding SelectedTransportIndex}"
                                          ToolTip="Choose the MCP server: remote Learn (HTTP) or a local server you authored (stdio)." />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,4"
                                        Visibility="{Binding ShowMcpUrl, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="MCP URL:" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Width="240" Text="{Binding McpUrl, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,4"
                                        Visibility="{Binding ShowLocalServerPath, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Server path:" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Width="300" Text="{Binding LocalServerPath, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Path to the LearnMcpTutorial.Server project (launched via dotnet run over stdio)." />
                            </StackPanel>
                            <Button Content="Connect" Command="{Binding ConnectCommand}" Width="80"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                    Background="#0078D4" Foreground="White" FontWeight="SemiBold"
                                    ToolTip="Connect to the MCP server to discover tools." />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Row 1: Tool Count -->
                <TextBlock Grid.Row="1" Margin="4,0,0,6" Foreground="Gray">
                    <Run Text="Discovered:" />
                    <Run Text="{Binding DiscoveredTools.Count, Mode=OneWay}" />
                    <Run Text=" tools available" />
                </TextBlock>

                <!-- Row 2: Question + Ask -->
                <Border Grid.Row="2" Padding="8" Margin="0,0,0,6"
                        BorderBrush="#0078D4" BorderThickness="1" CornerRadius="4" Background="#F0F6FF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Ask a question about Microsoft technologies"
                                       FontWeight="SemiBold" Margin="0,0,0,4" />
                            <TextBox Grid.Row="1" x:Name="QuestionBox" Height="50"
                                     Text="{Binding Question, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                     ToolTip="Type your question and press Ctrl+Enter or click Ask.">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding AskCommand}" />
                                    <KeyBinding Key="Enter" Modifiers="Shift" Command="{Binding AskCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <Button Content="Ask" Command="{Binding AskCommand}"
                                    Width="90" Height="40" Margin="0,0,0,8"
                                    FontSize="16" FontWeight="Bold"
                                    Background="#0078D4" Foreground="White"
                                    IsEnabled="{Binding CanAsk}"
                                    ToolTip="First connect to MCP, then ask your question (Ctrl+Enter or Shift+Enter)" />
                            <Button Content="Clear" Command="{Binding ClearCommand}"
                                    Width="90" Height="30"
                                    ToolTip="Clear the question, answer, and trace." />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Row 3: Tools | Trace / Answer -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="250" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" MinWidth="250" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Discovered Tools -->
                    <DockPanel Grid.Column="0">
                        <TextBlock DockPanel.Dock="Top" Text="Discovered Tools" FontWeight="Bold" Margin="0,0,0,4" />
                        <ListBox ItemsSource="{Binding DiscoveredTools}"
                                 BorderBrush="{StaticResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                 BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ToolInfo}">
                                    <StackPanel Margin="4,2">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock Text="{Binding Description}" Foreground="Gray"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="360" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="{StaticResource {x:Static SystemColors.ActiveBorderBrushKey}}" />

                    <!-- Right: Trace + Answer/Sources -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="5" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Trace -->
                        <DockPanel Grid.Row="0">
                            <TextBlock DockPanel.Dock="Top" Text="Tool Call Trace" FontWeight="Bold" Margin="0,0,0,4" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ToolCallTrace}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:TraceEntry}">
                                            <Border Padding="4,2" BorderThickness="0,0,0,1"
                                                    BorderBrush="{StaticResource {x:Static SystemColors.ControlLightBrushKey}}">
                                                <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="11">
                                                    <Run Text="{Binding Icon, Mode=OneWay}" />
                                                    <Run Text="  " />
                                                    <Run Text="{Binding Message, Mode=OneWay}" />
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>

                        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                      Background="{StaticResource {x:Static SystemColors.ActiveBorderBrushKey}}" />

                        <!-- Answer + Sources -->
                        <DockPanel Grid.Row="2">
                            <TextBlock DockPanel.Dock="Top" Text="Answer and Sources" FontWeight="Bold" Margin="0,0,0,4" />
                            <FlowDocumentScrollViewer
                                Document="{Binding Answer, Mode=OneWay, Converter={StaticResource MarkdownConverter}}"
                                HorizontalScrollBarVisibility="Auto"
                                MinHeight="60"
                                BorderBrush="{StaticResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                BorderThickness="1" Margin="0,0,0,4" />
                            <ItemsControl DockPanel.Dock="Bottom"
                                          ItemsSource="{Binding Sources}"
                                          Visibility="{Binding Sources.Count, Converter={StaticResource CountToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Mode=OneWay}" Cursor="Hand"
                                                   Foreground="Blue" TextDecorations="Underline"
                                                   FontSize="11" Margin="0,0,0,2"
                                                   MouseLeftButtonDown="SourceUrl_Click" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Grid>
                </Grid>

                <!-- Row 4: Status Bar -->
                <Border Grid.Row="4" Padding="6" Margin="0,6,0,0"
                        BorderBrush="{StaticResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="1" CornerRadius="2">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10"
                                     Fill="{Binding IsConnected, Converter={StaticResource StatusToColor}}"
                                     Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
                        </StackPanel>
                        <ProgressBar Width="120" Height="12" IsIndeterminate="True"
                                     HorizontalAlignment="Right"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
        <TabItem Header="Architecture">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel Margin="16">

                    <!-- ===== LIVE STATUS BANNER ===== -->
                    <Border Padding="12" Margin="0,0,0,16" CornerRadius="6" BorderThickness="2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="BorderBrush" Value="#D0D0D0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Background" Value="#FFF8E1" />
                                        <Setter Property="BorderBrush" Value="#FFA000" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="#E8F5E9" />
                                        <Setter Property="BorderBrush" Value="#4CAF50" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25CF; " FontSize="16" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Foreground" Value="#FFA000" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Foreground" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding ArchitectureStatus}" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="MCP Grounding Architecture" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />

                    <!-- ===== DIAGRAM 1: High-Level Architecture (INTERACTIVE) ===== -->
                    <TextBlock Text="1. High-Level Architecture" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border Padding="20" Margin="0,0,0,20" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,16" Foreground="#444">
                                Each component highlights in real-time as the connection and AI pipeline flow through it.
                                Watch the boxes glow as you connect and ask questions!
                            </TextBlock>

                            <!-- Flow boxes -->
                            <UniformGrid Columns="3" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <!-- WPF App -->
                                <Border CornerRadius="8" Padding="16" Margin="8" MinWidth="180">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#0078D4" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="3" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HighlightedComponent}" Value="WpfApp">
                                                    <Setter Property="Background" Value="#00A6FF" />
                                                    <Setter Property="BorderBrush" Value="#FFD700" />
                                                    <Setter Property="BorderThickness" Value="4" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="WPF Demo App" FontSize="14" FontWeight="Bold" Foreground="White" TextAlignment="Center" />
                                        <TextBlock Text="MVVM Client" FontSize="10" Foreground="#CCE0FF" TextAlignment="Center" />
                                        <TextBlock Text="Provider Selection" FontSize="9" Foreground="#CCE0FF" TextAlignment="Center" />
                                        <TextBlock Text="Tool-Call Tracing" FontSize="9" Foreground="#CCE0FF" TextAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- MCP Server -->
                                <Border CornerRadius="8" Padding="16" Margin="8" MinWidth="180">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#107C10" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="3" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HighlightedComponent}" Value="McpServer">
                                                    <Setter Property="Background" Value="#1DB954" />
                                                    <Setter Property="BorderBrush" Value="#FFD700" />
                                                    <Setter Property="BorderThickness" Value="4" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="MCP Server" FontSize="14" FontWeight="Bold" Foreground="White" TextAlignment="Center" />
                                        <TextBlock Text="learn.microsoft.com/api/mcp" FontSize="9" Foreground="#D4F0D4" TextAlignment="Center" />
                                        <TextBlock Text="Streamable HTTP Protocol" FontSize="9" Foreground="#D4F0D4" TextAlignment="Center" />
                                        <TextBlock Text="No Authentication Required" FontSize="9" Foreground="#D4F0D4" TextAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- Microsoft Learn -->
                                <Border CornerRadius="8" Padding="16" Margin="8" MinWidth="180">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#5C2D91" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="3" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HighlightedComponent}" Value="LearnDocs">
                                                    <Setter Property="Background" Value="#7B3FCC" />
                                                    <Setter Property="BorderBrush" Value="#FFD700" />
                                                    <Setter Property="BorderThickness" Value="4" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="Microsoft Learn" FontSize="14" FontWeight="Bold" Foreground="White" TextAlignment="Center" />
                                        <TextBlock Text="Documentation Pages" FontSize="10" Foreground="#D4CCF0" TextAlignment="Center" />
                                        <TextBlock Text="Code Samples &amp; Snippets" FontSize="10" Foreground="#D4CCF0" TextAlignment="Center" />
                                        <TextBlock Text="Azure CLI / .NET / Python" FontSize="10" Foreground="#D4CCF0" TextAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- LLM Provider box -->
                            <Border CornerRadius="8" Padding="12" HorizontalAlignment="Center" MinWidth="300">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#D83B01" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="3" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HighlightedComponent}" Value="LlmProvider">
                                                <Setter Property="Background" Value="#FF5722" />
                                                <Setter Property="BorderBrush" Value="#FFD700" />
                                                <Setter Property="BorderThickness" Value="4" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="LLM Provider " FontWeight="Bold" Foreground="White" FontSize="12" />
                                    <TextBlock Text="  OpenAI  |  DeepSeek  |  Ollama  (switchable via UI)" Foreground="#FFD4C4" FontSize="12" />
                                </StackPanel>
                            </Border>

                            <!-- Flow description -->
                            <StackPanel Margin="0,16,0,0">
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666">
                                    <Run Text="Flow: " FontWeight="Bold" />
                                    <Run Text="WPF App &#x2192; MCP Server (tool discovery &amp; invocation) &#x2192; Microsoft Learn (content retrieval)" />
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666" Margin="0,4,0,0">
                                    <Run Text="AI: WPF App &#x2192; LLM Provider &#x2192; Tool-calling loop &#x2192; Grounded Answer with Cited Sources" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ===== DIAGRAM 2: AI Pipeline Stack (INTERACTIVE) ===== -->
                    <TextBlock Text="2. AI Pipeline (Middleware Stack)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border Padding="20" Margin="0,0,0,20" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,16" Foreground="#444">
                                Each layer lights up as the pipeline processes your question. Watch the flow go from layer 1 &#x2192; 4 in real-time.
                            </TextBlock>

                            <!-- Layer 1: DocsAgent -->
                            <Border Padding="10,8" Margin="0,0,0,4" CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#7A9EC4" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="2" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePipelineStep}" Value="1">
                                                <Setter Property="Background" Value="#0078D4" />
                                                <Setter Property="BorderBrush" Value="#FFD700" />
                                                <Setter Property="BorderThickness" Value="3" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Foreground="White" FontSize="13">
                                        <Run Text="1. DocsAgent" FontWeight="Bold" />
                                        <Run Text=" — Entry point" />
                                    </TextBlock>
                                    <TextBlock Foreground="#E0E0E0" FontSize="10" TextWrapping="Wrap">
                                        Prepares system prompt with grounding rules, attaches discovered MCP tools to ChatOptions.Tools
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Layer 2: FunctionInvokingChatClient -->
                            <Border Padding="10,8" Margin="0,0,0,4" CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#B08060" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="2" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePipelineStep}" Value="2">
                                                <Setter Property="Background" Value="#D83B01" />
                                                <Setter Property="BorderBrush" Value="#FFD700" />
                                                <Setter Property="BorderThickness" Value="3" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Foreground="White" FontSize="13">
                                        <Run Text="2. FunctionInvokingChatClient" FontWeight="Bold" />
                                        <Run Text=" — Tool-calling loop" />
                                    </TextBlock>
                                    <TextBlock Foreground="#E0E0E0" FontSize="10" TextWrapping="Wrap">
                                        LLM requests a tool call &#x2192; middleware executes it &#x2192; result fed back to LLM &#x2192; repeat (max 10 iterations)
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Layer 3: ToolCallTracingChatClient -->
                            <Border Padding="10,8" Margin="0,0,0,4" CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#8A7AAA" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="2" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePipelineStep}" Value="3">
                                                <Setter Property="Background" Value="#5C2D91" />
                                                <Setter Property="BorderBrush" Value="#FFD700" />
                                                <Setter Property="BorderThickness" Value="3" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Foreground="White" FontSize="13">
                                        <Run Text="3. ToolCallTracingChatClient" FontWeight="Bold" />
                                        <Run Text=" — IChatClient wrapper" />
                                    </TextBlock>
                                    <TextBlock Foreground="#E0E0E0" FontSize="10" TextWrapping="Wrap">
                                        Intercepts every GetResponseAsync, classifies each step (tool request vs text), fires callback for UI trace
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Layer 4: LLM Provider -->
                            <Border Padding="10,8" Margin="0,0,0,4" CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#555555" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="2" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePipelineStep}" Value="4">
                                                <Setter Property="Background" Value="#333333" />
                                                <Setter Property="BorderBrush" Value="#FFD700" />
                                                <Setter Property="BorderThickness" Value="3" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Foreground="White" FontSize="13">
                                        <Run Text="4. LLM Provider (OpenAI / DeepSeek / Ollama)" FontWeight="Bold" />
                                        <Run Text=" — Raw API" />
                                    </TextBlock>
                                    <TextBlock Foreground="#CCC" FontSize="10" TextWrapping="Wrap">
                                        Sends chat messages + tool definitions to the LLM API. All three use OpenAI-compatible API.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ===== DIAGRAM 3: Tool Call Sequence (INTERACTIVE) ===== -->
                    <TextBlock Text="3. End-to-End Tool Call Sequence" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Border Padding="20" Margin="0,0,0,20" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,12" Foreground="#444">
                                Each step highlights as it happens in real-time. Switch to this tab while asking a question to see the full flow.
                            </TextBlock>

                            <!-- Step 1 -->
                            <Border Padding="10" Margin="0,0,0,6" CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F0F0F0" />
                                        <Setter Property="BorderBrush" Value="#D0D0D0" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveSequenceStep}" Value="1">
                                                <Setter Property="Background" Value="#F0F6FF" />
