# ── LLM Provider Feature Flag ──────────────────────────────────────────────
# Set Llm:Provider to "openai", "deepseek", or "ollama" (default: openai).
# Each provider has its own section in appsettings.json with model, URL, etc.

# ── Provider API keys ──────────────────────────────────────────────────────
# For OpenAI:   set OPENAI_API_KEY (or OpenAI__ApiKey in user-secrets)
# For DeepSeek: set DEEPSEEK_API_KEY (or DeepSeek__ApiKey in user-secrets)
# For Ollama:   no key needed (runs locally)

OPENAI_API_KEY=sk-your-key-here
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ── Override provider settings (optional — defaults are in appsettings.json) ─
# OpenAI__ModelId=gpt-4o
# DeepSeek__ModelId=deepseek-v4-flash
# DeepSeek__BaseUrl=https://api.deepseek.com/v1
# Ollama__ModelId=llama3.2
# Ollama__BaseUrl=http://localhost:11434/v1

# ── MCP ────────────────────────────────────────────────────────────────────
# Mcp__Url=https://learn.microsoft.com/api/mcp
# Mcp__MaxTokenBudget=2000
